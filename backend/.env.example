# PostgreSQL connection (Railway provides DATABASE_URL automatically)
DATABASE_URL=jdbc:postgresql://localhost:5432/taskmanager
DB_USERNAME=postgres
DB_PASSWORD=postgres

# JWT - use a long random string in production
JWT_SECRET=yourSuperSecretKeyMustBeAtLeast32CharactersLong

# Server port (Railway injects PORT automatically)
PORT=8080

# JVM memory limit for Railway free tier
JAVA_OPTS=-Xmx256m
