# ===== Supabase Postgres (transaction pooler, port 6543 / PgBouncer) =====
# From Supabase dashboard: Project Settings -> Database -> Connection string -> Transaction pooler
PGHOST=aws-1-ap-south-1.pooler.supabase.com
PGPORT=6543
PGDATABASE=postgres
PGUSER=postgres.<your-project-ref>
PGPASSWORD=<your-supabase-db-password>

# ===== JWT - use a long random string (>=32 chars) in production =====
JWT_SECRET=yourSuperSecretKeyMustBeAtLeast32CharactersLong

# ===== Server =====
PORT=8080

# ===== Redis (local Redis / Memurai). Use 127.0.0.1 to avoid IPv6 (::1) issues =====
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
